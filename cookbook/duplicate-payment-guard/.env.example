# Copy to .env and fill in. .env is gitignored — never commit a real key.
OPENAI_API_KEY=sk-proj-REPLACE_ME

# Model the agent runs on (kept cheap by default).
KIFF_COOKBOOK_MODEL=openai/gpt-4o-mini

# Internal wiring (defaults work with the bundled docker-compose).
KIFF_BASE_URL=http://kiff-decide:8081
AP_APP_URL=http://ap-app:8082
OPENCLAW_GATEWAY_URL=ws://openclaw:18789
